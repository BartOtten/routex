defmodule Routex.MatchMapTest do
  use ExUnit.Case
  import Routex.MatchMap

  @template "/foo/:id/bar/"
  @static_path "/foo/3/bar/?k1=v1&k2=v2#top"
  @static_uri "http://some.com:80" <> @static_path

  describe "the parser of `MatchMap` should" do
    test "return the same given an url and a path" do
      assert parse(@static_path) == parse(@static_uri)
    end

    test "create matchable maps" do
      :ok
    end
  end
end
